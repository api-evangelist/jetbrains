{
  "opencollection": "1.0.0",
  "info": {
    "name": "JetBrains Hub REST API",
    "version": "2024.1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Users",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "JetBrains List Users",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/users",
            "params": [
              {
                "name": "fields",
                "value": "",
                "type": "query"
              },
              {
                "name": "$skip",
                "value": "",
                "type": "query"
              },
              {
                "name": "$top",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns a list of Hub users."
        },
        {
          "info": {
            "name": "JetBrains Get User",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/users/:userId",
            "params": [
              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns details of a specific user."
        }
      ]
    },
    {
      "info": {
        "name": "Groups",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "JetBrains List User Groups",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/usergroups"
          },
          "docs": "Returns a list of user groups."
        }
      ]
    },
    {
      "info": {
        "name": "Projects",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "JetBrains List Projects",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/projects"
          },
          "docs": "Returns a list of Hub projects."
        }
      ]
    },
    {
      "info": {
        "name": "Roles",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "JetBrains List Roles",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/roles"
          },
          "docs": "Returns a list of defined roles."
        }
      ]
    },
    {
      "info": {
        "name": "Permissions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "JetBrains List Permissions",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/permissions"
          },
          "docs": "Returns a list of permissions."
        }
      ]
    },
    {
      "info": {
        "name": "Default",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "JetBrains List Services",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/services"
          },
          "docs": "Returns a list of connected services."
        }
      ]
    },
    {
      "info": {
        "name": "OAuth2",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "JetBrains List OAuth2 Clients",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instance}.youtrack.cloud/hub/api/rest/oauth2clients"
          },
          "docs": "Returns a list of registered OAuth2 clients."
        }
      ]
    }
  ],
  "bundled": true
}